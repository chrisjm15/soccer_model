      <Command>C:\Windows\System32\WindowsPowerShell\v1.0\powershell.exe</Command>
      <Arguments>-ExecutionPolicy Bypass -NonInteractive -File "C:\Users\chris\Documents\Claude\Projects\Sports Betting - Soccer\scripts\run_update.ps1"</Arguments>
